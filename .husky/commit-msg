#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# ==========================================
# Commit Message Hook
# ==========================================
# Validates commit messages follow conventional commits
#
# Format: <type>(<scope>): <subject>
#
# Types:
# - feat:     New feature
# - fix:      Bug fix
# - docs:     Documentation changes
# - style:    Code style changes (formatting, etc.)
# - refactor: Code refactoring
# - perf:     Performance improvements
# - test:     Adding or updating tests
# - chore:    Build process or auxiliary tool changes
# - ci:       CI/CD changes
# ==========================================

# Run commitlint nur, wenn es tatsächlich auflösbar ist. `npx --no` bricht sonst
# mit Exit 1 ab (Package nicht installiert) und blockiert jeden Commit.
if command -v npx > /dev/null 2>&1 && npx --no -- commitlint --version > /dev/null 2>&1; then
  npx --no -- commitlint --edit "$1"
else
  echo "⚠️  commitlint not available, skipping commit message validation"
fi
