#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# ==========================================
# Pre-Push Hook
# ==========================================
# Runs before pushing to remote to ensure code quality
#
# Checks:
# - Full test suite
# - TypeScript compilation
# - Build process
# ==========================================

echo "🚀 Running pre-push checks..."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

FAILED=0

# ==========================================
# 1. Run Full Test Suite
# ==========================================
echo "🧪 Running full test suite..."

if [ -f "package.json" ]; then
  # --if-present: fehlt das test-Script (Root hat keins), wird sauber übersprungen
  npm run test --if-present -- --coverage --passWithNoTests

  if [ $? -ne 0 ]; then
    echo "${RED}✗${NC} Tests failed"
    FAILED=1
  else
    echo "${GREEN}✓${NC} All tests passed"
  fi
fi

echo ""

# ==========================================
# 2. Run Tests in Each Service
# ==========================================
echo "🔧 Running service-specific tests..."

for service_dir in apps/*/; do
  if [ -f "$service_dir/package.json" ]; then
    service_name=$(basename "$service_dir")
    echo "  Testing: $service_name"

    (cd "$service_dir" && npm run test --if-present -- --passWithNoTests)

    if [ $? -ne 0 ]; then
      echo "${RED}✗${NC} Tests failed in $service_name"
      FAILED=1
    else
      echo "${GREEN}✓${NC} Tests passed in $service_name"
    fi
  fi
done

echo ""

# ==========================================
# 3. TypeScript Compilation
# ==========================================
echo "📘 Running TypeScript compilation..."

for service_dir in apps/*/; do
  if [ -f "$service_dir/tsconfig.json" ]; then
    service_name=$(basename "$service_dir")

    # tsc auflösen: Service-lokal > Root-Bin; sonst überspringen statt hart failen
    if [ -x "$service_dir/node_modules/.bin/tsc" ]; then
      TSC="$service_dir/node_modules/.bin/tsc"
    elif [ -x "node_modules/.bin/tsc" ]; then
      TSC="node_modules/.bin/tsc"
    else
      echo "  ${YELLOW}⚠${NC} tsc nicht installiert — überspringe $service_name"
      continue
    fi

    echo "  Compiling: $service_name"
    "$TSC" --noEmit -p "$service_dir/tsconfig.json"

    if [ $? -ne 0 ]; then
      echo "${RED}✗${NC} TypeScript compilation failed in $service_name"
      FAILED=1
    else
      echo "${GREEN}✓${NC} TypeScript compilation passed in $service_name"
    fi
  fi
done

echo ""

# ==========================================
# 4. Check for Untracked Files
# ==========================================
echo "📂 Checking for untracked files..."

UNTRACKED=$(git ls-files --others --exclude-standard | wc -l)

if [ $UNTRACKED -gt 0 ]; then
  echo "${YELLOW}⚠${NC} You have $UNTRACKED untracked files:"
  git ls-files --others --exclude-standard | head -10 | sed 's/^/  /'

  if [ $UNTRACKED -gt 10 ]; then
    echo "  ... and $((UNTRACKED - 10)) more"
  fi

  echo ""
  echo "  Consider adding them to .gitignore if they shouldn't be tracked"
  echo "  (This is a warning, not blocking the push)"
fi

echo ""

# ==========================================
# Summary
# ==========================================
if [ $FAILED -eq 1 ]; then
  echo "${RED}✗ Pre-push checks failed${NC}"
  echo ""
  echo "Please fix the errors above before pushing."
  echo ""
  echo "To skip these checks (NOT recommended):"
  echo "  git push --no-verify"
  echo ""
  exit 1
else
  echo "${GREEN}✅ All pre-push checks passed!${NC}"
  echo ""
  echo "Safe to push! 🚀"
  echo ""
  exit 0
fi
