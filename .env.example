# ==========================================
# SF-1 Ultimate - Environment Configuration
# ==========================================
#
# ⚠️  CRITICAL SECURITY WARNING ⚠️
# DO NOT use default values in production!
# ALL secrets MUST be changed before deployment!
#
# Generate secure secrets with:
# openssl rand -base64 32
# ==========================================

# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=production

# ==========================================
# DATABASE PASSWORDS
# ==========================================
# PostgreSQL (Auth Service)
# CRITICAL: Must be strong password (min 16 chars)
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD_MIN_16_CHARS

# MongoDB (Journal, Community, Tools, etc.)
# CRITICAL: Must be strong password (min 16 chars)
MONGODB_ROOT_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD_MIN_16_CHARS
MONGO_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD_MIN_16_CHARS

# Redis (Caching & Job Queues)
# CRITICAL: Must be strong password (min 16 chars)
REDIS_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD_MIN_16_CHARS

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# 🔴 CRITICAL: JWT_SECRET MUST BE SET! 🔴
# If not set, authentication will be INSECURE!
# Generate with: openssl rand -base64 64
# Minimum 32 characters required
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# Refresh Token Secret (must be different from JWT_SECRET)
# Generate with: openssl rand -base64 64
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# ==========================================
# DATABASE URLS (Auto-generated from above)
# ==========================================
DATABASE_URL=postgresql://sf1_user:${POSTGRES_PASSWORD}@localhost:5432/sf1_auth
MONGODB_URL=mongodb://sf1_admin:${MONGO_PASSWORD}@localhost:27017/sf1_main?authSource=admin
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# ==========================================
# EXTERNAL SERVICES (Optional)
# ==========================================
# OpenAI API Key (for AI-Service)
# Get from: https://platform.openai.com/api-keys
# Optional: AI-Service will work with mock data if not set
OPENAI_API_KEY=sk-CHANGE_ME_OR_LEAVE_EMPTY

# Meilisearch API Key (for Search-Service)
# Generate with: openssl rand -base64 32
MEILISEARCH_API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL
MEILISEARCH_MASTER_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# ==========================================
# TRAEFIK API GATEWAY
# ==========================================
# Admin Dashboard Password
# Generate with: openssl rand -base64 32
TRAEFIK_ADMIN_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL

# ==========================================
# CORS & SECURITY
# ==========================================
# Frontend URL (for CORS)
CORS_ORIGIN=https://seedfinderpro.de

# API Base URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# ==========================================
# MONITORING (Grafana)
# ==========================================
# Grafana Admin Credentials
# CRITICAL: Change default password!
# Access Grafana at: http://localhost:3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ==========================================
# OAUTH PROVIDERS
# ==========================================
# Google OAuth (für Social Login)
# Einrichten: https://console.cloud.google.com/ → APIs & Credentials
# Authorized redirect URI: https://seedfinderpro.de/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth (nicht implementiert — Platzhalter)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ==========================================
# SMTP (E-Mail-Versand)
# ==========================================
# Empfohlen: Brevo (brevo.com) — kostenlos bis 300 Mails/Tag
# Port 587 ist auf Hetzner geblockt → Port 2525 verwenden
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your-brevo-smtp-user@smtp-brevo.com
SMTP_PASS=your-brevo-smtp-password
SMTP_FROM=noreply@seedfinderpro.de

# ==========================================
# S3 / OBJECT STORAGE (Foto-Upload)
# ==========================================
# Hetzner Object Storage: https://console.hetzner.cloud/
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_BUCKET=sf1-uploads
S3_REGION=eu-central
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
# Legacy AWS SDK Vars (werden intern genutzt)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ==========================================
# STRIPE (Premium-Mitgliedschaft)
# ==========================================
# Dashboard: https://dashboard.stripe.com/
# Test Keys: sk_test_... / pk_test_...
# Live Keys: sk_live_... / pk_live_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook Secret nach Anlage unter: Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# Preis-IDs der angelegten Abo-Produkte
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...
FRONTEND_URL=https://seedfinderpro.de

# ==========================================
# SENTRY (Error Tracking)
# ==========================================
# https://sentry.io/ → Projekte anlegen: sf1-frontend + sf1-backend
SENTRY_DSN_FRONTEND=https://...@sentry.io/...
SENTRY_DSN_BACKEND=https://...@sentry.io/...
SENTRY_FIX_EMAIL=your-email@example.com
SENTRY_WEBHOOK_SECRET=

# ==========================================
# CDN (Cloudflare — optional)
# ==========================================
# Leer lassen bis Cloudflare eingerichtet ist
NEXT_PUBLIC_CDN_URL=

# ==========================================
# BETA-MODUS
# ==========================================
BETA_LIMIT=50
BETA_END_DATE=2026-04-07
BETA_ADMIN_EMAIL=admin@example.com

# ==========================================
# TELEGRAM (Push-Benachrichtigungen, optional)
# ==========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==========================================
# INTERNE SERVICE-URLS
# ==========================================
NOTIFICATION_SERVICE_URL=http://notification-service:3006
SEARCH_SERVICE_URL=http://search-service:3007
INTERNAL_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ==========================================
# DEPLOYMENT CHECKLIST
# ==========================================
# Vor dem ersten Deploy alles abhaken:
# [ ] ALLE Passwörter von CHANGE_ME geändert (Postgres, Mongo, Redis)
# [ ] JWT_SECRET generiert: openssl rand -base64 64
# [ ] JWT_REFRESH_SECRET generiert (ANDERS als JWT_SECRET)
# [ ] OPENAI_API_KEY gesetzt (wenn KI-Features genutzt werden)
# [ ] SMTP konfiguriert und Passwort-Reset getestet
# [ ] S3 Bucket angelegt, Keys eingetragen
# [ ] Stripe Keys eingetragen + Webhook registriert
# [ ] TRAEFIK_DASHBOARD_USERS gesetzt
# [ ] GRAFANA_ADMIN_PASSWORD geändert
# [ ] CORS_ORIGIN auf Produktions-Domain gesetzt
# [ ] FRONTEND_URL auf Produktions-Domain gesetzt
# [ ] Google OAuth Callback-URL in Google Console eingetragen (wenn OAuth genutzt)
# ==========================================
